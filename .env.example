# ==============================================================================
# Arenix -- Environment Variable Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================================

# -- LLM Provider API Keys ----------------------------------------------------
# Set the key(s) for whichever provider(s) you intend to use.
# Unused providers can be left blank.

OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-google-gemini-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# -- Custom / OpenRouter Endpoint ---------------------------------------------
# Use when provider = "custom" (OpenRouter, Azure OpenAI, local vLLM, etc.)

ARENIX_CUSTOM_API_KEY=your-custom-endpoint-api-key
ARENIX_CUSTOM_BASE_URL=https://openrouter.ai/api/v1
# ARENIX_CUSTOM_HEADERS={"HTTP-Referer":"https://yoursite.com"}
# ARENIX_CUSTOM_TIMEOUT_SECONDS=60
# ARENIX_CUSTOM_MODEL_ALIASES={"alias":"real-model-name"}

# -- Session Configuration ----------------------------------------------------
# All have safe defaults -- override only what you need.

# ARENIX_SESSION_ID=            # auto-generated UUID if omitted
ARENIX_INDUSTRY=default         # default | fintech | healthcare | government | tech

ARENIX_ATTACKER_PROVIDER=mock   # mock | openai | anthropic | gemini | deepseek | ollama | custom
ARENIX_ATTACKER_MODEL=mock-attacker

ARENIX_TARGET_PROVIDER=mock
ARENIX_TARGET_MODEL=mock-target

ARENIX_ANALYZER_PROVIDER=mock
ARENIX_ANALYZER_MODEL=mock-analyzer

ARENIX_OBSERVER_PROVIDER=mock
ARENIX_OBSERVER_MODEL=mock-observer

# -- Simulation Parameters ----------------------------------------------------

ARENIX_MAX_TURNS=12
ARENIX_TEMPERATURE=0.2
ARENIX_ATTACK_PROFILE=balanced        # balanced | aggressive | stealth
ARENIX_STOP_ON_BREAK=true
ARENIX_REQUIRE_OBSERVER_CONFIRMATION=true
ARENIX_MAX_RETRIES=3
ARENIX_ENABLE_SEMANTIC=false

# -- Output -------------------------------------------------------------------

ARENIX_EXPORT_JSON_PATH=arenix_report.json
